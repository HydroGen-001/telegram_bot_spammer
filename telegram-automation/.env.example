# Telegram API credentials
# Get from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Phone number for the account (international format)
PHONE=+79990000000

# =============================================================================
# PROXY (для обхода блокировок в России)
# =============================================================================
# Mobile proxy recommended for stable connection

PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Example (HTTP/SOCKS5 proxy):
# PROXY_ENABLED=true
# PROXY_HOST=proxy.example.com
# PROXY_PORT=8080
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass
